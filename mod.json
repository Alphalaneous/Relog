{
	"geode": "5.6.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "alphalaneous.relog",
	"name": "Relog",
	"version": "v1.1.0",
	"developer": "Alphalaneous",
	"description": "Show console log in GD",
	"dependencies": {
		"alphalaneous.alphas-ui-pack": "v1.1.0"
	},
	"resources": {
		"fonts": {
			"Consolas": {
				"path": "resources/Consolas.ttf",
				"size": 55
			}
		},
		"sprites": [
			"resources/*.png"
		]
	},
	"early-load": true,
	"tags": ["developer", "utility", "offline", "enhancement"],
		"links": {
		"homepage": "https://linktr.ee/Alphalaneous",
		"source": "https://github.com/Alphalaneous/Relog",
		"community": "https://discord.gg/Txn2CA5dHF"
	},
	"settings": {
		"toggle-console": {
			"type": "button",
			"buttons": {
				"toggle": "Toggle Console"
			}
		},
		"toggle-console-keybind": {
			"type": "keybind",
			"name": "Toggle Console Keybind",
			"default": ["Ctrl+F1"],
			"description": "The key used to open and close the console window."
		},
		"font-size": {
			"name": "Font Size",
			"type": "float",
			"min": 0.85,
			"max": 3,
			"default":  {
				"win": 1.0,
				"mac": 1.0,
				"android": 1.5,
				"ios": 1.5
			},
			"controls": {
				"arrows": true,
				"arrow-step": 0.05,
				"big-arrows": false,
				"slider": true,
				"slider-step": 0.05,
				"input": true
			}
		},
		"log-limit": {
			"name": "Log Limit",
			"description": "The maximum amount of logs that can be shown, ones past this limit will be removed.",
			"type": "int",
			"min": 100,
			"max": 5000,
			"default": 500
		},
		"blur-title": {
			"type": "title",
			"name": "Blur"
		},
		"enable-blur": {
			"name": "Enabled",
			"type": "bool",
			"default": true,
			"description": "Add blur behind the console window.",
			"enable-if": "loaded:thesillydoggo.blur-api",
			"enable-if-description": "Requires the \"Blur API\" mod to be installed."
		},
		"blur-passes": {
			"name": "Passes",
			"type": "int",
			"description": "The blur quality",
			"enable-if": "loaded:thesillydoggo.blur-api",
			"enable-if-description": "Requires the \"Blur API\" mod to be installed.",
			"min": 3,
			"max": 10,
			"default": {
				"win": 5,
				"mac": 5,
				"android": 3,
				"ios": 3
			}
		}
	}
}
